{
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "a/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/a(.*)",
      "dest": "/a/index.js"
    },
    {
      "src": "/api(.*)",
      "dest": "/api/index.js"
    }
  ]
}
